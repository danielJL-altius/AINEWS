# NewsAPI.ai (Event Registry) — https://newsapi.ai/
NEWSAPI_AI_KEY=e29c75b9-8da8-44a2-8dea-d86db249ddaf

# Anthropic Claude API — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Mailgun — https://www.mailgun.com/ (optional: leave API key or domain blank to write emails to disk)
MAILGUN_API_KEY=
# Verified domain in Mailgun (e.g. mg.yourdomain.com)
MAILGUN_DOMAIN=
# us or eu (api.mailgun.net vs api.eu.mailgun.net)
MAILGUN_REGION=us

# Email delivery
FROM_EMAIL=news@altius.capital
FROM_NAME=Altius Daily News
TO_EMAILS=daniel.leubitz@altius.capital,tomers@altius.capital
REPLY_TO=daniel.leubitz@altius.capital

# Runtime
TIMEZONE=America/New_York
LLM_MODEL=claude-sonnet-4-6
DB_PATH=data/news.db

# Watchlist / Keyword alerts (comma-separated phrases; Event Registry OR-query — keep concise)
# Example: WATCHLIST_KEYWORDS=Acme Partners,Our Firm Name LLC,Portfolio Co Inc
WATCHLIST_KEYWORDS=
MAX_KEYWORD_ALERT_ARTICLES=32

# Forward-to-ingest (Mailgun Route → inbound_server.py)
# Webhook URL: https://your-host/webhooks/inbound-email?token=THIS_SECRET
INBOUND_WEBHOOK_SECRET=
# Optional: comma-separated allowlist (emails and/or @domain). Empty = any sender with valid token.
FORWARD_ALLOWED_SENDERS=
